# Server
PORT=3001
# Dev: Vite on 5173. Production single-port: set to your public URL (e.g. http://localhost:3001).
CLIENT_URL=http://localhost:5173

# Auth — required
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3001

# Encrypts user API keys at rest (recommended — generate with: openssl rand -base64 32)
ENCRYPTION_KEY=change-me-to-another-long-random-string

# Envelope encryption provider: local (default), aws_kms, vault, gcp_kms
# KMS_PROVIDER=local

# Optional: disable self-serve sign-up (default: sign-up enabled)
# DISABLE_SIGN_UP=true

# Optional: server default OpenAI key for anonymous demo mode only
# ALLOW_SERVER_DEMO_KEY=false disables even when OPENAI_API_KEY is set
ALLOW_SERVER_DEMO_KEY=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol

# MCP security (stdio disabled by default)
MCP_ALLOW_STDIO=false
# MCP_STDIO_ALLOWLIST=npx,node,uvx,python,python3
# MCP_AUTO_EXECUTE_TOOLS=false

# GitHub OAuth for Desktop (demo data when unset)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Optional: demo user seed overrides
SEED_USER_EMAIL=demo@buselligence.com
SEED_USER_PASSWORD=demo123456
SEED_USER_NAME=Demo User
