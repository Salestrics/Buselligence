# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Auth — required
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3001

# Encrypts user API keys at rest (recommended — generate with: openssl rand -base64 32)
ENCRYPTION_KEY=change-me-to-another-long-random-string

# Optional: disable self-serve sign-up (default: sign-up enabled)
# DISABLE_SIGN_UP=true

# Optional: server default OpenAI key for anonymous demo mode only
# Signed-in users always use their own BYOK keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: demo user seed overrides
SEED_USER_EMAIL=demo@buselligence.com
SEED_USER_PASSWORD=demo123456
SEED_USER_NAME=Demo User
